
        // ========== ANALYTICS FUNCTIONS ==========
        function updateEmployerAnalytics() {
            const myJobs = getEmployerJobs();
            const relatedApplications = [];
            myJobs.forEach(function(job) {
                state.applications.forEach(function(app) {
                    if (app.jobId === job.id) relatedApplications.push(app);
                });
            });
            const accepted = relatedApplications.filter(function(a) { return a.status === "accepted"; }).length;
            const completed = relatedApplications.filter(function(a) { return a.status === "completed"; }).length;
            const rate = relatedApplications.length > 0 ? Math.round((completed / relatedApplications.length) * 100) : 0;
            document.getElementById("employerAcceptedAnalyticsMetric").textContent = accepted;
            document.getElementById("employerCompletedAnalyticsMetric").textContent = completed;
            document.getElementById("employerCompletionRateMetric").textContent = rate + "%";
        }

        function updateWorkerAnalytics() {
            const applications = getCurrentWorkerApplications();
            const pending = applications.filter(function(a) { return a.status === "pending"; }).length;
            const completed = applications.filter(function(a) { return a.status === "completed"; }).length;
            const rate = applications.length > 0 ? Math.round((completed / applications.length) * 100) : 0;
            document.getElementById("workerPendingAnalyticsMetric").textContent = pending;
            document.getElementById("workerCompletedAnalyticsMetric").textContent = completed;
            document.getElementById("workerSuccessRateMetric").textContent = rate + "%";
        }

        function completeShift(applicationId) {
            setApplicationStatus(applicationId, "completed");
        }

