generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  role      String   // "worker" or "client"
  skills    Json?
  district  String?
  createdAt DateTime @default(now())
  
  jobs          Job[]          @relation("ClientJobs")
  applications  Application[]
}

model Worker {
  id         String   @id @default(uuid())
  name       String
  skill      String
  rating     Float    @default(0)
  jobsCount  Int      @default(0)
  phone      String   @unique
  district   String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  applications Application[]
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String   @map("desc")
  district    String
  category    String
  priceMin    Int      @map("price_min")
  priceMax    Int      @map("price_max")
  views       Int      @default(0)
  applicants  Int      @default(0)
  status      String   @default("open") // "open", "in_progress", "completed"
  postedAt    DateTime @default(now())  @map("posted_at")
  
  clientId    String?  @map("client_id")
  client      User?    @relation("ClientJobs", fields: [clientId], references: [id])
  
  applications Application[]
}

model Application {
  id        String   @id @default(uuid())
  status    String   @default("pending") // "pending", "accepted", "rejected"
  appliedAt DateTime @default(now()) @map("applied_at")
  
  jobId     String   @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id])
  
  workerId  String   @map("worker_id")
  worker    Worker   @relation(fields: [workerId], references: [id])
  
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  createdAt DateTime @default(now())
  
  @@unique([userId, jobId])
}

model JobAlert {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  category  String?
  district  String?
  createdAt DateTime @default(now())
}
