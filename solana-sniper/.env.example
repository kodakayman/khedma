# One or more RPC endpoints (comma-separated). Use paid providers for production.
# Examples: Helius, QuickNode, Triton.
SOLANA_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=xxx,https://your-quicknode-endpoint
# Optional legacy single-endpoint fallback:
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional WS endpoints (comma-separated, aligned by index with SOLANA_RPC_URLS)
SOLANA_WS_URLS=wss://mainnet.helius-rpc.com/?api-key=xxx,wss://your-quicknode-endpoint
# Optional legacy single-endpoint fallback:
# SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Multi-wallet support: provide one or more private keys (comma-separated or JSON array)
SOLANA_PRIVATE_KEYS=
# Optional single key fallback:
# SOLANA_PRIVATE_KEY=

LOG_LEVEL=info

# Program IDs are configurable in case they change
RAYDIUM_PROGRAM_ID=675kPX9MHTjS2zt1qfr1NYHuzefQ9J4A7QmR2F4f8dk
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Start safely in dry-run mode. Set to false for live trading.
DRY_RUN=true

# RPC resilience tuning
RPC_MAX_RETRIES=5
RPC_BASE_BACKOFF_MS=250
RPC_MAX_BACKOFF_MS=4000
RPC_RATE_LIMIT_COOLDOWN_MS=1500

# Event parser tuning
PARSER_BATCH_SIZE=16
PARSER_BATCH_WINDOW_MS=80
PARSER_CIRCUIT_BREAKER_THRESHOLD=20
PARSER_CIRCUIT_BREAKER_COOLDOWN_MS=12000

# Optional token metadata API list (comma-separated)
TOKEN_METADATA_URLS=https://token.jup.ag/all,https://cache.jup.ag/tokens

# Optional Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Twitter/X API v2 (for social sentiment scoring)
TWITTER_BEARER_TOKEN=
